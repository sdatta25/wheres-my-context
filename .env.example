# ─────────────────────────────────────────────────────────────
# Where's My Context — configuration
# Copy to `.env` and fill in to enable a real memory backend.
# With NOTHING set, the app runs on the built-in Demo Engine.
# ─────────────────────────────────────────────────────────────

# --- Option A: Local Cognee (self-hosted graph, needs an LLM key) ---
# MEMORY_ENGINE=cognee
# LLM_API_KEY=sk-...            # OpenAI-compatible key Cognee uses to cognify

# --- Option B: Cognee Cloud (managed memory) ---
# MEMORY_ENGINE=cognee_cloud
# COGNEE_API_KEY=your-cognee-cloud-api-key
# COGNEE_BASE_URL=https://api.cognee.ai

# --- Server ---
# PORT=8000
